#!/usr/bin/env node
/**
 * sheets — read/write Google Sheets for coaching data
 *
 * Usage:
 *   sheets init                          # create tabs + headers if missing
 *   sheets log-workout '<json>'          # append row to Workout Log tab
 *   sheets log-plan '<json>'             # append row to Weekly Plans tab
 *   sheets log-recovery '<json>'         # append row to Recovery Trends tab
 *   sheets get-plan [--week YYYY-MM-DD]  # read plan for given week (default: current)
 *   sheets get-workouts [--days N]       # read last N days from Workout Log (default: 7)
 *
 * Credentials read from env (or auto-loaded from .env):
 *   GOOGLE_SHEETS_KEY_JSON  — base64-encoded service account JSON
 *   GOOGLE_SHEETS_ID        — spreadsheet ID
 */

'use strict';

const https  = require('https');
const fs     = require('fs');
const path   = require('path');
const crypto = require('crypto');

// ── Load .env when running on host ────────────────────────────────────────────

(function loadDotEnv() {
  if (fs.existsSync('/workspace/group')) return;
  const candidates = [
    path.join(__dirname, '.env'),
    path.join(__dirname, '..', '.env'),
    path.join(__dirname, '..', '..', '.env'),
    path.join(__dirname, '..', '..', '..', '.env'),
  ];
  for (const f of candidates) {
    if (!fs.existsSync(f)) continue;
    for (const line of fs.readFileSync(f, 'utf8').split('\n')) {
      const t  = line.trim();
      if (!t || t.startsWith('#')) continue;
      const eq = t.indexOf('=');
      if (eq < 0) continue;
      const key = t.slice(0, eq).trim();
      const val = t.slice(eq + 1).trim().replace(/^["']|["']$/g, '');
      if (!(key in process.env)) process.env[key] = val;
    }
    break;
  }
})();

// ── Config ────────────────────────────────────────────────────────────────────

const SHEETS_API  = 'https://sheets.googleapis.com/v4/spreadsheets';
const TOKEN_URL   = 'https://oauth2.googleapis.com/token';
// Token cache: shared store/ — same file on host and container. Prevents
// host/container from invalidating each other's rotated refresh_token.
function resolveTokenCache(name) {
  const containerStore = '/workspace/project/store';
  try { fs.accessSync(containerStore, fs.constants.W_OK); return `${containerStore}/${name}`; }
  catch {}
  if (fs.existsSync('/workspace/group')) return `/workspace/group/${name}`;
  return path.join(__dirname, '..', '..', '..', 'store', name);
}
const TOKEN_CACHE = resolveTokenCache('.sheets-tokens.json');

const TAB_PLANS     = 'Weekly Plans';
const TAB_WORKOUTS  = 'Workout Log';
const TAB_RECOVERY  = 'Recovery Trends';
const TAB_FITNESS   = 'Fitness Trend';

const HEADERS = {
  [TAB_PLANS]:    ['Week Start', 'Week #', 'Phase', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun', 'Volume Target (km)', 'Coach Notes'],
  [TAB_WORKOUTS]: ['Date', 'Day', 'Sport', 'Distance (km)', 'Duration', 'Avg HR', 'Avg Pace / Power', 'Status', 'Notes', 'Coach Note'],
  [TAB_RECOVERY]: ['Date', 'Recovery %', 'HRV (ms)', 'RHR', 'SpO2 %', 'Strain', 'Sleep Score %', 'Sleep Duration', 'Coach Note'],
  [TAB_FITNESS]:  ['Date', 'VDOT', 'AE Index', '7d Avg HRV', '28d Volume (km)', '7d Avg Recovery %'],
};

// ── HTTP helpers ──────────────────────────────────────────────────────────────

function httpRequest(method, url, token, bodyObj) {
  return new Promise((resolve, reject) => {
    const body = bodyObj ? JSON.stringify(bodyObj) : null;
    const u    = new URL(url);
    const opts = {
      hostname: u.hostname,
      path:     u.pathname + u.search,
      method,
      headers: {
        Authorization: `Bearer ${token}`,
        'Content-Type': 'application/json',
        ...(body ? { 'Content-Length': Buffer.byteLength(body) } : {}),
      },
    };
    const req = https.request(opts, res => {
      let raw = '';
      res.on('data', c => (raw += c));
      res.on('end', () => {
        try { resolve({ status: res.statusCode, body: JSON.parse(raw) }); }
        catch { resolve({ status: res.statusCode, body: raw }); }
      });
    });
    req.on('error', reject);
    if (body) req.write(body);
    req.end();
  });
}

function httpPostForm(url, formData) {
  return new Promise((resolve, reject) => {
    const body = new URLSearchParams(formData).toString();
    const u    = new URL(url);
    const opts = {
      hostname: u.hostname,
      path:     u.pathname + u.search,
      method:   'POST',
      headers: {
        'Content-Type':   'application/x-www-form-urlencoded',
        'Content-Length': Buffer.byteLength(body),
      },
    };
    const req = https.request(opts, res => {
      let raw = '';
      res.on('data', c => (raw += c));
      res.on('end', () => {
        try { resolve({ status: res.statusCode, body: JSON.parse(raw) }); }
        catch { resolve({ status: res.statusCode, body: raw }); }
      });
    });
    req.on('error', reject);
    req.write(body);
    req.end();
  });
}

// ── JWT + Token management ────────────────────────────────────────────────────

function base64url(input) {
  return Buffer.from(input)
    .toString('base64')
    .replace(/\+/g, '-')
    .replace(/\//g, '_')
    .replace(/=/g, '');
}

function makeJWT(clientEmail, privateKey) {
  const now     = Math.floor(Date.now() / 1000);
  const header  = base64url(JSON.stringify({ alg: 'RS256', typ: 'JWT' }));
  const payload = base64url(JSON.stringify({
    iss:   clientEmail,
    scope: 'https://www.googleapis.com/auth/spreadsheets',
    aud:   TOKEN_URL,
    exp:   now + 3600,
    iat:   now,
  }));
  const unsigned  = `${header}.${payload}`;
  const sign      = crypto.createSign('RSA-SHA256');
  sign.update(unsigned);
  const signature = sign.sign(privateKey, 'base64')
    .replace(/\+/g, '-')
    .replace(/\//g, '_')
    .replace(/=/g, '');
  return `${unsigned}.${signature}`;
}

function loadKeyJson() {
  const raw = process.env.GOOGLE_SHEETS_KEY_JSON;
  if (!raw) die('GOOGLE_SHEETS_KEY_JSON is not set.\nSee setup instructions in the sheets skill SKILL.md.');
  try {
    return JSON.parse(Buffer.from(raw, 'base64').toString('utf8'));
  } catch {
    die('GOOGLE_SHEETS_KEY_JSON is not valid base64-encoded JSON.');
  }
}

function loadTokenCache() {
  try { return JSON.parse(fs.readFileSync(TOKEN_CACHE, 'utf8')); }
  catch { return null; }
}

function saveTokenCache(token, expiresAt) {
  try {
    fs.mkdirSync(path.dirname(TOKEN_CACHE), { recursive: true });
    fs.writeFileSync(TOKEN_CACHE, JSON.stringify({ token, expiresAt }, null, 2));
  } catch { /* non-fatal */ }
}

async function getAccessToken() {
  const cache = loadTokenCache();
  if (cache && cache.token && cache.expiresAt > Date.now() + 60000) {
    return cache.token;
  }

  const key    = loadKeyJson();
  const jwt    = makeJWT(key.client_email, key.private_key);
  const res    = await httpPostForm(TOKEN_URL, {
    grant_type: 'urn:ietf:params:oauth:grant-type:jwt-bearer',
    assertion:  jwt,
  });

  if (res.status !== 200 || !res.body.access_token) {
    die(`Token request failed (HTTP ${res.status}): ${JSON.stringify(res.body)}`);
  }

  const expiresAt = Date.now() + (res.body.expires_in || 3600) * 1000;
  saveTokenCache(res.body.access_token, expiresAt);
  return res.body.access_token;
}

// ── Sheets API helpers ────────────────────────────────────────────────────────

function sheetId() {
  const id = process.env.GOOGLE_SHEETS_ID;
  if (!id) die('GOOGLE_SHEETS_ID is not set.');
  return id;
}

async function getSpreadsheetMeta(token) {
  const url = `${SHEETS_API}/${sheetId()}?fields=sheets.properties,sheets.charts`;
  const res = await httpRequest('GET', url, token);
  if (res.status !== 200) die(`Failed to get spreadsheet metadata (HTTP ${res.status}): ${JSON.stringify(res.body)}`);
  return res.body;
}

async function createSheet(token, title) {
  const url = `${SHEETS_API}/${sheetId()}:batchUpdate`;
  const res = await httpRequest('POST', url, token, {
    requests: [{ addSheet: { properties: { title } } }],
  });
  if (res.status !== 200) die(`Failed to create sheet "${title}" (HTTP ${res.status}): ${JSON.stringify(res.body)}`);
}

async function batchWriteValues(token, data) {
  const url = `${SHEETS_API}/${sheetId()}/values:batchUpdate`;
  const res = await httpRequest('POST', url, token, { valueInputOption: 'USER_ENTERED', data });
  if (res.status !== 200) die(`Failed to write values (HTTP ${res.status}): ${JSON.stringify(res.body)}`);
}

async function clearRange(token, range) {
  const r   = encodeURIComponent(range);
  const url = `${SHEETS_API}/${sheetId()}/values/${r}:clear`;
  const res = await httpRequest('POST', url, token, {});
  if (res.status !== 200) die(`Failed to clear range "${range}" (HTTP ${res.status}): ${JSON.stringify(res.body)}`);
}

async function appendRows(token, tabName, rows) {
  const range = encodeURIComponent(`${tabName}!A1`);
  const url   = `${SHEETS_API}/${sheetId()}/values/${range}:append?valueInputOption=USER_ENTERED&insertDataOption=INSERT_ROWS`;
  const res   = await httpRequest('POST', url, token, { values: rows });
  if (res.status !== 200) die(`Failed to append rows to "${tabName}" (HTTP ${res.status}): ${JSON.stringify(res.body)}`);
  return res.body;
}

async function readRows(token, tabName, range) {
  const r   = encodeURIComponent(range || `${tabName}!A:Z`);
  const url = `${SHEETS_API}/${sheetId()}/values/${r}`;
  const res = await httpRequest('GET', url, token);
  if (res.status !== 200) die(`Failed to read "${tabName}" (HTTP ${res.status}): ${JSON.stringify(res.body)}`);
  return res.body.values || [];
}

// ── Fitness calculation helpers ───────────────────────────────────────────────

// VDOT from Jack Daniels formula. Returns null if inputs are invalid/too easy.
function calcVdot(distanceM, timeSec) {
  if (!distanceM || !timeSec || distanceM < 1000) return null;
  const t   = timeSec / 60;                   // minutes
  const v   = distanceM / t;                  // m/min
  const pct = 0.8 + 0.1894393 * Math.exp(-0.012778 * t)
                  + 0.2989558 * Math.exp(-0.1932605 * t);
  const vo2 = -4.60 + 0.182258 * v + 0.000104 * v * v;
  const vdot = vo2 / pct;
  if (vdot < 30 || vdot > 85) return null; // sanity bounds
  return Math.round(vdot * 10) / 10;
}

// AE Index: running speed (m/min) / avg_hr * 100. Higher = more aerobically efficient.
function calcAE(distanceM, timeSec, avgHr) {
  if (!avgHr || avgHr < 80 || !distanceM || !timeSec) return null;
  const speedMperMin = distanceM / (timeSec / 60);
  return Math.round((speedMperMin / avgHr) * 100) / 100;
}

// Classify Strava running activity into effort type
function classifyEffort(distanceM, timeSec, sufferScore) {
  const paceSecPerKm = timeSec / (distanceM / 1000);
  const distKm       = distanceM / 1000;
  const suffer       = sufferScore || 0;
  if (suffer >= 130 && paceSecPerKm <= 4 * 60 + 15) return 'Race';
  if (suffer >= 60  && paceSecPerKm <= 4 * 60 + 30 && distKm >= 5) return 'Tempo';
  if (distKm >= 18) return 'Long';
  return 'Easy';
}

function fmtTime(totalSec) {
  // Always use H:MM:SS so Sheets stores as proper duration, not mis-parsed as "HH:MM" (43h 01m)
  const ts = Math.round(totalSec);
  const h  = Math.floor(ts / 3600);
  const m  = Math.floor((ts % 3600) / 60);
  const s  = ts % 60;
  return `${h}:${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`;
}

function fmtPace(distanceM, timeSec) {
  const secPerKm = timeSec / (distanceM / 1000);
  const m = Math.floor(secPerKm / 60);
  const s = Math.round(secPerKm % 60);
  return `${m}:${String(s).padStart(2, '0')}/km`;
}

// ── External API token helpers (for backfill) ─────────────────────────────────

async function getStravaToken() {
  const cacheFile = resolveTokenCache('.strava-tokens.json');

  const clientId     = process.env.STRAVA_CLIENT_ID;
  const clientSecret = process.env.STRAVA_CLIENT_SECRET;
  const envRefresh   = process.env.STRAVA_REFRESH_TOKEN;

  let cache = null;
  try { cache = JSON.parse(fs.readFileSync(cacheFile, 'utf8')); } catch {}

  const now = Date.now();
  if (cache && cache.access_token && cache.expires_at > now + 60000) return cache.access_token;

  const refreshToken = (cache && cache.refresh_token) || envRefresh;
  if (!clientId || !clientSecret || !refreshToken) {
    die('Strava credentials missing. Set STRAVA_CLIENT_ID, STRAVA_CLIENT_SECRET, STRAVA_REFRESH_TOKEN in .env');
  }

  const res = await httpPostForm('https://www.strava.com/oauth/token', {
    client_id:     clientId,
    client_secret: clientSecret,
    refresh_token: refreshToken,
    grant_type:    'refresh_token',
  });
  if (res.status !== 200 || !res.body.access_token) die(`Strava token refresh failed: ${JSON.stringify(res.body)}`);

  const newCache = {
    access_token:  res.body.access_token,
    refresh_token: res.body.refresh_token || refreshToken,
    expires_at:    now + (res.body.expires_in || 21600) * 1000,
  };
  try {
    fs.mkdirSync(path.dirname(cacheFile), { recursive: true });
    fs.writeFileSync(cacheFile, JSON.stringify(newCache, null, 2));
  } catch {}
  return newCache.access_token;
}

async function getWhoopToken() {
  const cacheFile = fs.existsSync('/workspace/group')
    ? '/workspace/group/.whoop-tokens.json'
    : path.join(__dirname, '..', '..', '..', 'store', '.whoop-tokens.json');

  const clientId     = process.env.WHOOP_CLIENT_ID;
  const clientSecret = process.env.WHOOP_CLIENT_SECRET;
  const envRefresh   = process.env.WHOOP_REFRESH_TOKEN;

  let cache = null;
  try { cache = JSON.parse(fs.readFileSync(cacheFile, 'utf8')); } catch {}

  const now = Date.now();
  if (cache && cache.access_token && cache.expires_at > now + 60000) return cache.access_token;

  const refreshToken = (cache && cache.refresh_token) || envRefresh;
  if (!clientId || !clientSecret || !refreshToken) {
    die('WHOOP credentials missing. Set WHOOP_CLIENT_ID, WHOOP_CLIENT_SECRET, WHOOP_REFRESH_TOKEN in .env');
  }

  const res = await httpPostForm('https://api.prod.whoop.com/oauth/oauth2/token', {
