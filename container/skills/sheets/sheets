async function cmdGetFitness(days) {
  const token  = await getAccessToken();
  const rows   = await readRows(token, TAB_FITNESS);
  if (rows.length <= 1) return 'No fitness data logged yet. Run: sheets backfill-fitness';

  const cutoff = daysAgo(days);
  const data   = rows.slice(1).filter(r => r[0] && r[0] >= cutoff);

  if (!data.length) return `No fitness data in the last ${days} days.`;

  // Cols: 0=Date 1=VDOT 2=AE Index 3=7d HRV 4=28d Volume 5=7d Recovery %
  const lines = [`── Fitness Trend: last ${days} days ─────────────────────`];
  for (const r of data) {
    const vdot = r[1] ? `VDOT ${r[1]}` : '        —';
    const ae   = r[2] ? `AE ${r[2]}` : '';
    const hrv  = r[3] ? `HRV ${r[3]}ms` : '';
    const vol  = r[4] ? `28d ${r[4]}km` : '';
    const rec  = r[5] ? `Rec ${r[5]}%` : '';
    const meta = [ae, hrv, vol, rec].filter(Boolean).join('  ·  ');
    lines.push(`  [${r[0]}] ${vdot}`);
    if (meta) lines.push(`         ${meta}`);
  }

  const vdots = data.map(r => parseFloat(r[1])).filter(v => !isNaN(v));
  if (vdots.length >= 2) {
    lines.push('');
    lines.push(`  VDOT range: ${Math.min(...vdots)} → ${Math.max(...vdots)} (${vdots.length} quality efforts)`);
    const recent3 = vdots.slice(-3);
    const early3  = vdots.slice(0, 3);
    if (recent3.length >= 2 && early3.length >= 2) {
      const trend = (recent3.reduce((a,b) => a+b,0)/recent3.length) - (early3.reduce((a,b) => a+b,0)/early3.length);
      lines.push(`  Trend: ${trend > 0 ? '+' : ''}${trend.toFixed(1)} VDOT vs start of period`);
    }
  }

  return lines.join('\n');
}

async function cmdBackfillFitness() {
  const token = await getAccessToken();
  process.stderr.write('Reading Workout Log...\n');

  // ── 1. Read Workout Log ────────────────────────────────────────────────────
  // Cols: 0=Date 1=Day 2=Sport 3=Distance(km) 4=Duration 5=HR 6=Pace/Power 7=Status 8=Notes 9=CoachNote
  const runTypes   = new Set(['Run', 'VirtualRun', 'TrailRun']);
  const workoutRows = await readRows(token, TAB_WORKOUTS);

  // Parse duration string "H:MM:SS" → seconds
  function parseDuration(raw) {
    if (!raw) return 0;
    if (typeof raw === 'number') return Math.round(raw * 86400); // Sheets TIME fraction
    const parts = String(raw).split(':').map(Number);
    if (parts.length === 3) return parts[0] * 3600 + parts[1] * 60 + parts[2];
    if (parts.length === 2) return parts[0] * 60 + parts[1];
    return 0;
  }

  const runs = [];
  for (const r of workoutRows.slice(1)) {
    const date  = r[0];
    const sport = r[2];
    if (!date || !runTypes.has(sport)) continue;
    const distKm = parseFloat(r[3]) || 0;
    if (distKm < 0.5) continue;
    const durationSec = parseDuration(r[4]);
    if (durationSec < 60) continue;
    const avgHr = parseFloat(r[5]) || null;
    runs.push({ date, distKm, distM: distKm * 1000, durationSec, avgHr });
  }
  runs.sort((a, b) => a.date.localeCompare(b.date));
  process.stderr.write(`  ${runs.length} runs parsed\n`);

  // ── 2. Read Recovery Trends ────────────────────────────────────────────────
  // Cols: 0=Date 1=Recovery% 2=HRV 3=RHR 4=SpO2 5=Strain 6=Sleep Score 7=Sleep Duration 8=Coach Note
  process.stderr.write('Reading Recovery Trends...\n');
  const recoveryRows = await readRows(token, TAB_RECOVERY);
  const hrvByDate      = {};
  const recoveryByDate = {};
  for (const r of recoveryRows.slice(1)) {
    const date = r[0];
    if (!date) continue;
    const hrv = parseFloat(r[2]);
    const rec = parseFloat(r[1]);
    if (!isNaN(hrv)) hrvByDate[date]      = hrv;
    if (!isNaN(rec)) recoveryByDate[date] = rec;
  }
  process.stderr.write(`  ${Object.keys(hrvByDate).length} recovery records\n`);

  // ── 3. Rolling helpers ─────────────────────────────────────────────────────
  function rolling7d(byDate, date) {
    const vals = [];
    for (let i = 0; i < 7; i++) {
      const d = new Date(date + 'T12:00:00'); d.setDate(d.getDate() - i);
      const ds = d.toISOString().slice(0, 10);
      if (byDate[ds] != null) vals.push(byDate[ds]);
    }
    if (!vals.length) return null;
    return Math.round((vals.reduce((a, b) => a + b, 0) / vals.length) * 10) / 10;
  }

  function rolling28dVolume(date) {
    const cutoff = new Date(date + 'T12:00:00'); cutoff.setDate(cutoff.getDate() - 27);
    const cutoffStr = cutoff.toISOString().slice(0, 10);
    return Math.round(
      runs.filter(r => r.date >= cutoffStr && r.date <= date)
          .reduce((s, r) => s + r.distKm, 0) * 10
    ) / 10;
  }

  // ── 4. Build Fitness Trend rows (one per run) ──────────────────────────────
  const rows = runs.map(r => {
    const ae     = r.avgHr ? calcAE(r.distM, r.durationSec, r.avgHr) : null;
    const hrv7d  = rolling7d(hrvByDate, r.date);
    const rec7d  = rolling7d(recoveryByDate, r.date);
    const vol28d = rolling28dVolume(r.date);

    // VDOT only for quality efforts: pace ≤ 4:30/km, dist ≥ 5km
    const paceSecPerKm = r.durationSec / r.distKm;
    const vdot = (paceSecPerKm <= 270 && r.distKm >= 5) ? calcVdot(r.distM, r.durationSec) : null;

    return [
      r.date,
      vdot  != null ? vdot  : '',
      ae    != null ? ae    : '',
      hrv7d != null ? hrv7d : '',
      vol28d,
      rec7d != null ? rec7d : '',
    ];
  });

  // ── 5. Clear and rewrite Fitness Trend ────────────────────────────────────
  process.stderr.write('Rebuilding Fitness Trend tab...\n');
  await clearRange(token, `${TAB_FITNESS}!A1:Z10000`);
  await appendRows(token, TAB_FITNESS, [HEADERS[TAB_FITNESS]]);

  const BATCH = 200;
  for (let i = 0; i < rows.length; i += BATCH) {
    await appendRows(token, TAB_FITNESS, rows.slice(i, i + BATCH));
    process.stderr.write(`  Written ${Math.min(i + BATCH, rows.length)}/${rows.length}\n`);
  }

  const vdotCount = rows.filter(r => r[1] !== '').length;
  return `✓ Fitness Trend rebuilt from sheets: ${rows.length} rows (${vdotCount} with VDOT)`;
}

async function writeRow(token, tabName, rowIndex, values) {
  const lastCol = String.fromCharCode(64 + values.length);
  const range   = encodeURIComponent(`${tabName}!A${rowIndex}:${lastCol}${rowIndex}`);
  const url     = `${SHEETS_API}/${sheetId()}/values/${range}?valueInputOption=USER_ENTERED`;
  const res     = await httpRequest('PUT', url, token, { values: [values] });
  if (res.status !== 200) die(`Failed to write row (HTTP ${res.status}): ${JSON.stringify(res.body)}`);
}

async function cmdRewriteWorkoutLog() {
  process.stderr.write('Rewriting Workout Log...\n');
  const sheetsToken = await getAccessToken();
  const stravaToken = await getStravaToken();

  // Get numeric sheet ID for conditional formatting
  const meta         = await getSpreadsheetMeta(sheetsToken);
  const workoutSheet = (meta.sheets || []).find(s => s.properties.title === TAB_WORKOUTS);
  if (!workoutSheet) die('Workout Log tab not found. Run: sheets init');
  const wsId = workoutSheet.properties.sheetId;

  // 1. Clear data rows + rewrite header
  await clearRange(sheetsToken, `${TAB_WORKOUTS}!A1:Z10000`);  // clear full sheet incl. header + any stale cols
  await writeRow(sheetsToken, TAB_WORKOUTS, 1, HEADERS[TAB_WORKOUTS]);

  // 2. Fetch all Strava activities from 2024-01-01
  const afterTs = Math.floor(new Date('2024-01-01').getTime() / 1000);
  const allActs = [];
  let page = 1;
  while (true) {
    const q = new URL('https://www.strava.com/api/v3/athlete/activities');
    q.searchParams.set('after',    String(afterTs));
    q.searchParams.set('before',   String(Math.floor(Date.now() / 1000)));
    q.searchParams.set('per_page', '100');
    q.searchParams.set('page',     String(page));
    const res = await httpRequest('GET', q.toString(), stravaToken);
    if (res.status !== 200) throw new Error(`Strava ${res.status}: ${JSON.stringify(res.body)}`);
    if (!Array.isArray(res.body) || res.body.length === 0) break;
    allActs.push(...res.body);
    process.stderr.write(`  Strava page ${page}: ${res.body.length} activities\n`);
    if (res.body.length < 100) break;
    page++;
  }

  // 3. Sort by date descending — newest first
  allActs.sort((a, b) => b.start_date_local.localeCompare(a.start_date_local));

  const rows = allActs.map(a => {
    const date    = a.start_date_local.slice(0, 10);
    const distKm  = Math.round(a.distance / 100) / 10;
    const isRun   = ['Run', 'VirtualRun', 'TrailRun'].includes(a.type);
    const isRide  = ['Ride', 'VirtualRide', 'EBikeRide'].includes(a.type);
    let paceOrPower = '';
    if (isRun && a.distance > 0 && a.moving_time > 0) {
      paceOrPower = fmtPace(a.distance, a.moving_time);
    } else if (isRide && a.average_watts > 0) {
      paceOrPower = `${Math.round(a.average_watts)} W`;
    } else if (a.average_speed > 0) {
      paceOrPower = `${(a.average_speed * 3.6).toFixed(1)} km/h`;
    }
    return [
      date,
      dayName(date),
      a.type,
      distKm > 0 ? distKm : '',
      fmtTime(a.moving_time),
      a.average_heartrate ? Math.round(a.average_heartrate) : '',
      paceOrPower,
      '',         // Status — filled by evening task going forward
      a.name || '',
      '',         // Coach Note — filled by evening task going forward
    ];
  });

  process.stderr.write(`  Total activities: ${rows.length}\n`);

  // 4. Append in batches of 100
  const BATCH = 100;
  for (let i = 0; i < rows.length; i += BATCH) {
    await appendRows(sheetsToken, TAB_WORKOUTS, rows.slice(i, i + BATCH));
    process.stderr.write(`  Appended ${Math.min(i + BATCH, rows.length)}/${rows.length}\n`);
  }

  // 5. Format columns + conditional formatting by Status (col H = index 7)
  const deleteRules = (workoutSheet.conditionalFormats || []).map((_, i) => ({
    deleteConditionalFormatRule: { sheetId: wsId, index: 0 },
  }));

  const formatDateCol = {
    repeatCell: {
      range:  { sheetId: wsId, startRowIndex: 1, endRowIndex: 10000, startColumnIndex: 0, endColumnIndex: 1 },
      cell:   { userEnteredFormat: { numberFormat: { type: 'DATE', pattern: 'yyyy-mm-dd' } } },
      fields: 'userEnteredFormat.numberFormat',
    },
  };

  // Column E (index 4) = Duration — format as [h]:mm:ss elapsed time
  const formatDurCol = {
    repeatCell: {
      range:  { sheetId: wsId, startRowIndex: 1, endRowIndex: 10000, startColumnIndex: 4, endColumnIndex: 5 },
      cell:   { userEnteredFormat: { numberFormat: { type: 'TIME', pattern: '[h]:mm:ss' } } },
      fields: 'userEnteredFormat.numberFormat',
    },
  };

  // Conditional formatting: colour entire row based on Status (col H = index 7)
  const dataRange = {
    sheetId: wsId, startRowIndex: 1, endRowIndex: 10000,
    startColumnIndex: 0, endColumnIndex: 10,
  };
  function cfRule(formula, color) {
    return { addConditionalFormatRule: { index: 0, rule: {
      ranges: [dataRange],
      booleanRule: {
        condition: { type: 'CUSTOM_FORMULA', values: [{ userEnteredValue: formula }] },
        format:    { backgroundColor: color },
      },
    }}};
  }
  const green  = { red: 0.576, green: 0.769, blue: 0.490 };
  const yellow = { red: 1.0,   green: 0.898, blue: 0.600 };
  const red    = { red: 0.878, green: 0.400, blue: 0.400 };

  const allRequests = [
    formatDateCol,
    formatDurCol,
    ...deleteRules,
    cfRule('=$H2="hit"',     green),
    cfRule('=$H2="strong"',  green),
    cfRule('=$H2="weak"',    yellow),
    cfRule('=$H2="partial"', yellow),
    cfRule('=$H2="missed"',  red),
  ];

  const cfUrl = `${SHEETS_API}/${sheetId()}:batchUpdate`;
  const cfRes = await httpRequest('POST', cfUrl, sheetsToken, { requests: allRequests });
  if (cfRes.status !== 200) process.stderr.write(`  Warning: format setup failed: ${JSON.stringify(cfRes.body)}\n`);
  else process.stderr.write('  Formatting + conditional coloring applied\n');

  return `✓ Workout Log rewritten: ${rows.length} activities added`;
}

async function cmdAddCharts() {
  const token = await getAccessToken();
  const meta  = await getSpreadsheetMeta(token);

  const fitnessSheet = (meta.sheets || []).find(s => s.properties.title === TAB_FITNESS);
  if (!fitnessSheet) die('Fitness Trend tab not found. Run: sheets init first.');
  const fitSid = fitnessSheet.properties.sheetId;

  // ── 1. Clear the tab + ensure enough columns (need at least 28 for AA-AB) ───
  await clearRange(token, `${TAB_FITNESS}!A1:Z10000`);
  const expandGrid = await httpRequest('POST', `${SHEETS_API}/${sheetId()}:batchUpdate`, token, {
    requests: [{ updateSheetProperties: {
      properties: { sheetId: fitSid, gridProperties: { columnCount: 30 } },
      fields: 'gridProperties.columnCount',
    }}],
  });
  if (expandGrid.status !== 200) process.stderr.write(`  Warning: could not expand grid: ${JSON.stringify(expandGrid.body)}\n`);

  // ── 2. Write formula cells into hidden cols S-X (indices 18-23) ────────────
  //
  // Layout (all data hidden — charts float on cols A-N):
  //   Cols S-U = workout data  (Date | Distance | Avg HR)
  //   Cols V-X = recovery data (Date | HRV      | Recovery %)
  //
  //   Rows  1-10 = weekly  data  (FILTER current Mon–Sun, auto-resets)
  //   Rows 11-24 = monthly data  (AVERAGEIFS Jan–Dec of current year)

  // Hungarian locale (hu_HU): function args use ";" and array column separator is "\"
  const SEP = ';';   // function argument separator
  const ARR = '\\';  // array literal column separator (backslash)

  const W_MON  = `TODAY()-WEEKDAY(TODAY()${SEP}2)+1`;
  const W_SUN  = `TODAY()-WEEKDAY(TODAY()${SEP}2)+7`;
  const RUN_RE = `"*Run*"`;

  //
  // Layout (all hidden):
  //   S(18)=Date  T(19)=Dist  U(20)=HR  V(21)=AE  W(22)=VDOT  — workout
  //   X(23)=Date  Y(24)=HRV   Z(25)=Rec%              — recovery
  //   AA(26)=ARRAYFORMULA AE per Workout Log row
  //   AB(27)=ARRAYFORMULA VDOT per Workout Log row
  //   Rows  1-10 = weekly  (Mon–Sun)
  //   Rows 11-24 = monthly (Jan–Dec)

  function dt(m, y = 'YEAR(TODAY())') { return `DATE(${y}${SEP}${m}${SEP}1)`; }

  // ARRAYFORMULA helpers (written to AA2, AB2 — referenced by weekly FILTER and monthly AVERAGEIFS)
  const aeFormula =
    `=ARRAYFORMULA(IF(REGEXMATCH('Workout Log'!C$2:C${SEP}"Run")*('Workout Log'!F$2:F>0)*('Workout Log'!D$2:D>0)*('Workout Log'!E$2:E>0)${SEP}` +
    `ROUND(('Workout Log'!D$2:D*1000)/('Workout Log'!E$2:E*1440)/'Workout Log'!F$2:F*100${SEP}2)${SEP}""))`;

  // hu_HU locale: decimal separator is comma, not period. All decimal literals use commas.
  // Also use POWER() not ^ — ^ fails on array ranges in ARRAYFORMULA in hu_HU locale.
  const DEC = (n) => String(n).replace('.', ',');
  const vdotFormula =
    `=ARRAYFORMULA(IF(REGEXMATCH('Workout Log'!C$2:C${SEP}"Run")*('Workout Log'!D$2:D>=5)*('Workout Log'!E$2:E*86400/'Workout Log'!D$2:D<=270)*('Workout Log'!F$2:F>0)${SEP}` +
    `ROUND((${DEC(-4.6)}+${DEC(0.182258)}*('Workout Log'!D$2:D*1000/('Workout Log'!E$2:E*1440))+${DEC(0.000104)}*POWER('Workout Log'!D$2:D*1000/('Workout Log'!E$2:E*1440)${SEP}2))/` +
    `(${DEC(0.8)}+${DEC(0.1894393)}*EXP(${DEC(-0.012778)}*('Workout Log'!E$2:E*1440))+${DEC(0.2989558)}*EXP(${DEC(-0.1932605)}*('Workout Log'!E$2:E*1440)))${SEP}1)${SEP}""))`;

  // Weekly FILTER: 5-col workout (Date,Dist,HR,AE,VDOT), 3-col recovery (Date,HRV,Rec%)
  // AE and VDOT computed inline — avoids cross-sheet array dimension mismatch when using AA$2:AA
  const wCond = `('Workout Log'!A$2:A>=${W_MON})*('Workout Log'!A$2:A<=${W_SUN})*REGEXMATCH('Workout Log'!C$2:C${SEP}"Run")`;
  const inlineAE =
    `IFERROR(ROUND(('Workout Log'!D$2:D*1000)/('Workout Log'!E$2:E*1440)/'Workout Log'!F$2:F*100${SEP}2)${SEP}"")`;
  const inlineVDOT =
    `IFERROR(IF(('Workout Log'!D$2:D>=5)*('Workout Log'!E$2:E*86400/'Workout Log'!D$2:D<=270)*('Workout Log'!F$2:F>0)${SEP}` +
    `ROUND((${DEC(-4.6)}+${DEC(0.182258)}*('Workout Log'!D$2:D*1000/('Workout Log'!E$2:E*1440))+${DEC(0.000104)}*POWER('Workout Log'!D$2:D*1000/('Workout Log'!E$2:E*1440)${SEP}2))/(${DEC(0.8)}+${DEC(0.1894393)}*EXP(${DEC(-0.012778)}*('Workout Log'!E$2:E*1440))+${DEC(0.2989558)}*EXP(${DEC(-0.1932605)}*('Workout Log'!E$2:E*1440)))${SEP}1)${SEP}"")${SEP}"")`;
  const weeklyWorkoutFormula =
    `=IFERROR(SORT(FILTER({'Workout Log'!A$2:A${ARR}'Workout Log'!D$2:D${ARR}'Workout Log'!F$2:F${ARR}${inlineAE}${ARR}${inlineVDOT}}${SEP}${wCond})${SEP}1${SEP}TRUE)${SEP}"")`;

  const rCond = `('Recovery Trends'!A$2:A>=${W_MON})*('Recovery Trends'!A$2:A<=${W_SUN})`;
  const weeklyRecoveryFormula =
    `=IFERROR(SORT(FILTER({'Recovery Trends'!A$2:A${ARR}'Recovery Trends'!C$2:C${ARR}'Recovery Trends'!B$2:B}${SEP}${rCond})${SEP}1${SEP}TRUE)${SEP}"")`;

  // Monthly rows — SUMPRODUCT computes AE/VDOT inline from Workout Log only (no cross-sheet AVERAGEIFS)
  const WL = (col, r = '1000') => `'Workout Log'!${col}$2:${col}${r}`;
  const monthlyWorkoutRows = Array.from({ length: 12 }, (_, i) => {
    const m  = i + 1;
    const nm = m === 12 ? 1 : m + 1;
    const ny = m === 12 ? 'YEAR(TODAY())+1' : 'YEAR(TODAY())';
    const s  = dt(m); const e = dt(nm, ny);
    const crit = `'Workout Log'!A:A${SEP}">="&${s}${SEP}'Workout Log'!A:A${SEP}"<"&${e}`;
    // Shared condition for all runs in this month (bounded to 1000 rows)
    // IFERROR protects divisions that would error on empty rows (no short-circuit in SUMPRODUCT)
    const baseCond = `(${WL('A')}>=${s})*(${WL('A')}<${e})*REGEXMATCH(${WL('C')}${SEP}"Run")*(${WL('F')}>0)*(${WL('D')}>0)*(${WL('E')}>0)`;
    // AE = (dist_km*1000) / (dur_days*1440) / avg_hr * 100 — wrapped in IFERROR for D=0/E=0 rows
    const aeCalc = `IFERROR(${WL('D')}*1000/(${WL('E')}*1440)/${WL('F')}*100${SEP}0)`;
    // VDOT condition: pace ≤ 4:30/km (dur_days*86400/dist_km ≤ 270) and dist ≥ 5km
    // IFERROR on pace check to avoid #DIV/0! on D=0 rows in SUMPRODUCT (not short-circuited)
    const paceCond = `IFERROR(${WL('E')}*86400/${WL('D')}${SEP}999)<=270`;
    const vdotCond = `${baseCond}*(${WL('D')}>=5)*(${paceCond})`;
    const v  = `IFERROR(${WL('D')}*1000/(${WL('E')}*1440)${SEP}0)`;  // speed in m/min, 0 on error
    const vdotCalc =
      `IFERROR(ROUND((${DEC(-4.6)}+${DEC(0.182258)}*${v}+${DEC(0.000104)}*POWER(${v}${SEP}2))/(${DEC(0.8)}+${DEC(0.1894393)}*EXP(${DEC(-0.012778)}*${WL('E')}*1440)+${DEC(0.2989558)}*EXP(${DEC(-0.1932605)}*${WL('E')}*1440))${SEP}1)${SEP}0)`;
    return [
      `=${s}`,
      `=IF(SUMIFS('Workout Log'!D:D${SEP}'Workout Log'!C:C${SEP}${RUN_RE}${SEP}${crit})>0${SEP}SUMIFS('Workout Log'!D:D${SEP}'Workout Log'!C:C${SEP}${RUN_RE}${SEP}${crit})${SEP}"")`,
      `=IFERROR(AVERAGEIFS('Workout Log'!F:F${SEP}'Workout Log'!C:C${SEP}${RUN_RE}${SEP}'Workout Log'!F:F${SEP}">"&0${SEP}${crit})${SEP}"")`,
      `=IFERROR(ROUND(SUMPRODUCT(IF(${baseCond}${SEP}${aeCalc}${SEP}0))/SUMPRODUCT(${baseCond}*1)${SEP}2)${SEP}"")`,
      `=IFERROR(ROUND(SUMPRODUCT(IF(${vdotCond}${SEP}${vdotCalc}${SEP}0))/SUMPRODUCT(${vdotCond}*1)${SEP}1)${SEP}"")`,
    ];
  });

  const monthlyRecoveryRows = Array.from({ length: 12 }, (_, i) => {
    const m  = i + 1;
    const nm = m === 12 ? 1 : m + 1;
    const ny = m === 12 ? 'YEAR(TODAY())+1' : 'YEAR(TODAY())';
    const s  = dt(m); const e = dt(nm, ny);
    return [
      `=${s}`,
      `=IFERROR(AVERAGEIFS('Recovery Trends'!C:C${SEP}'Recovery Trends'!A:A${SEP}">="&${s}${SEP}'Recovery Trends'!A:A${SEP}"<"&${e})${SEP}"")`,
      `=IFERROR(AVERAGEIFS('Recovery Trends'!B:B${SEP}'Recovery Trends'!A:A${SEP}">="&${s}${SEP}'Recovery Trends'!A:A${SEP}"<"&${e})${SEP}"")`,
    ];
  });

  const tab = TAB_FITNESS;
  await batchWriteValues(token, [
    // ARRAYFORMULA computed cols AA, AB (AE and VDOT per Workout Log row)
    { range: `${tab}!AA2`, values: [[aeFormula]] },
    { range: `${tab}!AB2`, values: [[vdotFormula]] },
    // Weekly headers (row 1): workout S-W, recovery X-Z
    { range: `${tab}!S1:W1`, values: [['Date','Dist (km)','Avg HR (bpm)','AE Index','VDOT']] },
    { range: `${tab}!X1:Z1`, values: [['Date','HRV (ms)','Recovery %']] },
    // Weekly FILTER formulas row 2 (spill automatically)
    { range: `${tab}!S2`, values: [[weeklyWorkoutFormula]] },
    { range: `${tab}!X2`, values: [[weeklyRecoveryFormula]] },
    // Monthly headers row 11
    { range: `${tab}!S11:W11`, values: [['Month','Total Dist (km)','Avg HR (bpm)','Avg AE Index','Avg VDOT']] },
    { range: `${tab}!X11:Z11`, values: [['Month','Avg HRV (ms)','Avg Recovery %']] },
    // Monthly workout rows 12-23 (5 cols)
    { range: `${tab}!S12:W23`, values: monthlyWorkoutRows },
    // Monthly recovery rows 12-23 (3 cols)
    { range: `${tab}!X12:Z23`, values: monthlyRecoveryRows },
  ]);
  process.stderr.write('  Formula cells written\n');

  // ── 3. Build batchUpdate requests ──────────────────────────────────────────
  const deleteCharts = (fitnessSheet.charts || []).map(c => ({
    deleteEmbeddedObject: { objectId: c.chartId },
  }));

  // First reset number format across ALL hidden cols (S=18 through AB=27) to avoid stale date formats
  const clearNumFormat = {
    repeatCell: {
      range:  { sheetId: fitSid, startRowIndex: 0, endRowIndex: 24, startColumnIndex: 18, endColumnIndex: 28 },
      cell:   { userEnteredFormat: { numberFormat: { type: 'NUMBER', pattern: '' } } },
      fields: 'userEnteredFormat.numberFormat',
    },
  };

  // Then re-apply DATE format only to date cols S(18) and X(23)
  const formatDateCols = [18, 23].map(startCol => ({
    repeatCell: {
      range:  { sheetId: fitSid, startRowIndex: 1, endRowIndex: 24, startColumnIndex: startCol, endColumnIndex: startCol + 1 },
      cell:   { userEnteredFormat: { numberFormat: { type: 'DATE', pattern: 'mmm d' } } },
      fields: 'userEnteredFormat.numberFormat',
    },
  }));

  // Hide cols S-AB (indices 18-27)
  const hideCols = {
    updateDimensionProperties: {
      range: { sheetId: fitSid, dimension: 'COLUMNS', startIndex: 18, endIndex: 28 },
      properties: { hiddenByUser: true },
      fields: 'hiddenByUser',
    },
  };

  // Chart helper
  function gr(startRow, endRow, col) {
    return { sheetId: fitSid, startRowIndex: startRow, endRowIndex: endRow, startColumnIndex: col, endColumnIndex: col + 1 };
  }

  // S=18 T=19 U=20 V=21 W=22 X=23 Y=24 Z=25
  // Weekly rows 0-9, Monthly rows 10-23
  const W = { start: 0, end: 10 };
  const M = { start: 10, end: 24 };

  function makeChart(title, domainCol, series, axisLabels, anchorRow, anchorCol, rowRange, chartType = 'LINE') {
    return {
      addChart: {
        chart: {
          spec: {
            title,
            hiddenDimensionStrategy: 'SHOW_ALL',
            basicChart: {
              chartType,
              legendPosition: 'BOTTOM_LEGEND',
              axis: [
                { position: 'BOTTOM_AXIS', title: '' },
                { position: 'LEFT_AXIS',   title: axisLabels[0] },
                ...(axisLabels[1] ? [{ position: 'RIGHT_AXIS', title: axisLabels[1] }] : []),
              ],
              domains: [{ domain: { sourceRange: { sources: [gr(rowRange.start, rowRange.end, domainCol)] } } }],
              series: series.map(({ col, axis, type }) => ({
                series:     { sourceRange: { sources: [gr(rowRange.start, rowRange.end, col)] } },
                targetAxis: axis || 'LEFT_AXIS',
                ...(type ? { type } : {}),
              })),
              ...(chartType !== 'COLUMN' ? { interpolateNulls: true } : {}),
            },
          },
          position: {
            overlayPosition: {
              anchorCell:    { sheetId: fitSid, rowIndex: anchorRow, columnIndex: anchorCol },
              widthPixels:   620,
              heightPixels:  320,
            },
          },
        },
      },
    };
  }

  // 10 charts: 5 metrics × 2 periods. Left col=0 weekly, right col=9 monthly.
  // S=18 T=19 U=20 V=21 W=22 X=23 Y=24 Z=25
  const addCharts = [
    // Distance (row 0)
    makeChart('Distance / Week',        18, [{ col: 19 }],  ['km'],            0,  0, W, 'COLUMN'),
    makeChart('Distance / Month',       18, [{ col: 19 }],  ['km'],            0,  9, M, 'COLUMN'),
    // Avg HR (row 22)
    makeChart('Avg HR / Week',          18, [{ col: 20 }],  ['bpm'],          22,  0, W, 'LINE'),
    makeChart('Avg HR / Month',         18, [{ col: 20 }],  ['bpm'],          22,  9, M, 'LINE'),
    // AE Index (row 44)
    makeChart('AE Index / Week',        18, [{ col: 21 }],  ['AE Index'],     44,  0, W, 'LINE'),
    makeChart('AE Index / Month',       18, [{ col: 21 }],  ['AE Index'],     44,  9, M, 'LINE'),
    // VDOT (row 66)
    makeChart('VDOT / Week',            18, [{ col: 22 }],  ['VDOT'],         66,  0, W, 'LINE'),
    makeChart('VDOT / Month',           18, [{ col: 22 }],  ['VDOT'],         66,  9, M, 'LINE'),
    // HRV & Recovery (row 88)
    makeChart('HRV & Recovery / Week',  23,
      [{ col: 24, axis: 'LEFT_AXIS', type: 'LINE' }, { col: 25, axis: 'RIGHT_AXIS', type: 'COLUMN' }],
      ['HRV (ms)', 'Recovery %'],       88,  0, W, 'COMBO'),
    makeChart('HRV & Recovery / Month', 23,
      [{ col: 24, axis: 'LEFT_AXIS', type: 'LINE' }, { col: 25, axis: 'RIGHT_AXIS', type: 'COLUMN' }],
      ['HRV (ms)', 'Recovery %'],       88,  9, M, 'COMBO'),
  ];

  const requests = [clearNumFormat, ...formatDateCols, hideCols, ...deleteCharts, ...addCharts];
  const batchUrl = `${SHEETS_API}/${sheetId()}:batchUpdate`;
  const res = await httpRequest('POST', batchUrl, token, { requests });
  if (res.status !== 200) die(`Failed to add charts (HTTP ${res.status}): ${JSON.stringify(res.body)}`);

  return `✓ Fitness Trend rebuilt — 10 charts (weekly + monthly) for Distance, HR, AE Index, VDOT, HRV & Recovery`;
}

// ── Helpers ───────────────────────────────────────────────────────────────────

function parseJsonArg(str) {
  if (!str) die('JSON argument required.');
  try { return JSON.parse(str); }
  catch { die(`Invalid JSON: ${str}`); }
}

function die(msg) { console.error('Error:', msg); process.exit(1); }

function usage() {
  console.log(`Usage:
  sheets init
  sheets log-workout '<json>'
  sheets log-plan '<json>'
  sheets log-recovery '<json>'
  sheets log-fitness '<json>'
  sheets get-plan [--week YYYY-MM-DD]
  sheets get-workouts [--days N]
  sheets get-fitness [--days N]
  sheets backfill-fitness [--reset]
  sheets rewrite-workout-log
  sheets add-charts`);
  process.exit(1);
}

// ── Entry point ───────────────────────────────────────────────────────────────

async function main() {
  const args = process.argv.slice(2);
  const cmd  = args[0];
  if (!cmd) usage();

  try {
    let out;
    switch (cmd) {
      case 'init':         out = await cmdInit(); break;
      case 'log-workout':   out = await cmdLogWorkout(args[1]); break;
      case 'coach-note':    out = await cmdCoachNote(args[1]); break;
      case 'log-plan':     out = await cmdLogPlan(args[1]); break;
      case 'log-recovery': out = await cmdLogRecovery(args[1]); break;
      case 'get-plan': {
        const wIdx = args.indexOf('--week');
        out = await cmdGetPlan(wIdx >= 0 ? args[wIdx + 1] : null);
        break;
      }
      case 'get-workouts': {
        const dIdx = args.indexOf('--days');
        out = await cmdGetWorkouts(dIdx >= 0 ? parseInt(args[dIdx + 1]) || 7 : 7);
        break;
      }
      case 'log-fitness':  out = await cmdLogFitness(args[1]); break;
      case 'get-fitness': {
        const dIdx = args.indexOf('--days');
        out = await cmdGetFitness(dIdx >= 0 ? parseInt(args[dIdx + 1]) || 90 : 90);
        break;
      }
      case 'backfill-fitness':    out = await cmdBackfillFitness(args.includes('--reset')); break;
      case 'rewrite-workout-log': out = await cmdRewriteWorkoutLog(); break;
      case 'add-charts':          out = await cmdAddCharts(); break;
      default: usage();
    }
    console.log(out);
  } catch (err) {
    die(err.message);
  }
}

main();
