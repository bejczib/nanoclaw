  const newCache = {
    access_token:  res.body.access_token,
    refresh_token: res.body.refresh_token || refreshToken,
    expires_at:    now + (res.body.expires_in || 3600) * 1000,
  };
  try {
    fs.mkdirSync(path.dirname(cacheFile), { recursive: true });
    fs.writeFileSync(cacheFile, JSON.stringify(newCache, null, 2));
  } catch {}
  return newCache.access_token;
}

// ── Date helpers ──────────────────────────────────────────────────────────────

function todayStr() {
  return new Date().toISOString().slice(0, 10);
}

function dayName(dateStr) {
  return new Date(dateStr + 'T12:00:00').toLocaleDateString('en-US', { weekday: 'short' });
}

function daysAgo(n) {
  const d = new Date();
  d.setDate(d.getDate() - n);
  return d.toISOString().slice(0, 10);
}

function currentMondayStr() {
  const d   = new Date();
  const day = d.getDay(); // 0=Sun, 1=Mon...
  const diff = day === 0 ? -6 : 1 - day;
  d.setDate(d.getDate() + diff);
  return d.toISOString().slice(0, 10);
}

// ── Commands ──────────────────────────────────────────────────────────────────

async function cmdInit() {
  const token = await getAccessToken();
  const meta  = await getSpreadsheetMeta(token);
  const existing = new Set((meta.sheets || []).map(s => s.properties.title));

  const created = [];
  for (const tabName of [TAB_PLANS, TAB_WORKOUTS, TAB_RECOVERY, TAB_FITNESS]) {
    if (!existing.has(tabName)) {
      await createSheet(token, tabName);
      await appendRows(token, tabName, [HEADERS[tabName]]);
      created.push(tabName);
    }
  }

  if (created.length === 0) {
    return '✓ All tabs already exist: Weekly Plans, Workout Log, Recovery Trends, Fitness Trend';
  }
  return `✓ Created tabs: ${created.join(', ')}\n✓ Headers written`;
}

async function cmdLogWorkout(jsonStr) {
  const d     = parseJsonArg(jsonStr);
  const token = await getAccessToken();
  const date  = d.date || todayStr();
  const row   = [
    date,
    dayName(date),
    d.sport    || '',
    (d.actual_distance ?? d.distance) != null ? +(d.actual_distance ?? d.distance) : '',
    d.actual_duration || d.duration || '',
    d.avg_hr   != null ? +d.avg_hr   : '',
    d.avg_pace || d.avg_power || '',
    d.status     || '',
    d.notes      || '',
    d.coach_note || '',
  ];

  // Always append (insert at top so newest-first). Caller is responsible for not
  // re-processing the same workout — multiple workouts per day are supported.
  const meta  = await getSpreadsheetMeta(token);
  const sheet = (meta.sheets || []).find(s => s.properties.title === TAB_WORKOUTS);
  if (!sheet) die('Workout Log tab not found. Run: sheets init');
  const wsId  = sheet.properties.sheetId;

  const batchUrl = `${SHEETS_API}/${sheetId()}:batchUpdate`;
  const batchRes = await httpRequest('POST', batchUrl, token, {
    requests: [{
      insertDimension: {
        range: { sheetId: wsId, dimension: 'ROWS', startIndex: 1, endIndex: 2 },
        inheritFromBefore: false,
      },
    }],
  });
  if (batchRes.status !== 200) die(`Failed to insert row (HTTP ${batchRes.status}): ${JSON.stringify(batchRes.body)}`);

  await writeRow(token, TAB_WORKOUTS, 2, row);
  return `✓ Logged workout for ${date}: ${d.sport || 'activity'} ${d.distance ? d.distance + 'km' : ''} ${d.avg_pace || ''}`.trim();
}

// Write or update the Coach Note for a specific date's workout row
async function cmdCoachNote(jsonStr) {
  const d     = parseJsonArg(jsonStr);
  const token = await getAccessToken();
  const date  = d.date || todayStr();
  const note  = d.note || d.coach_note || '';
  if (!note) die('Provide "note" or "coach_note" field in JSON');

  // Find the row index with matching date
  const rows = await readRows(token, TAB_WORKOUTS);
  let rowIdx = -1;
  for (let i = 1; i < rows.length; i++) {
    if (rows[i][0] === date) { rowIdx = i + 1; break; } // 1-based sheet row
  }
  if (rowIdx === -1) die(`No workout row found for date ${date} in Workout Log`);

  // Write only column J (Coach Note = col 10, 1-based)
  const range = encodeURIComponent(`${TAB_WORKOUTS}!J${rowIdx}`);
  const url   = `${SHEETS_API}/${sheetId()}/values/${range}?valueInputOption=RAW`;
  const res   = await httpRequest('PUT', url, token, { values: [[note]] });
  if (res.status !== 200) die(`Failed to write coach note (HTTP ${res.status}): ${JSON.stringify(res.body)}`);
  return `✓ Coach note written to Workout Log row ${rowIdx} (${date})`;
}

async function cmdLogPlan(jsonStr) {
  const d = parseJsonArg(jsonStr);
  const token = await getAccessToken();

  const weekStart = d.week_start || currentMondayStr();
  const row = [
    `'${weekStart}`,
    d.week_num    != null ? String(d.week_num) : '',
    d.phase       || '',
    d.mon         || '',
    d.tue         || '',
    d.wed         || '',
    d.thu         || '',
    d.fri         || '',
    d.sat         || '',
    d.sun         || '',
    d.volume_target != null ? String(d.volume_target) : '',
    d.coach_notes || '',
  ];

  // Upsert: update existing row if week_start matches, otherwise append
  const rows = await readRows(token, TAB_PLANS);
  let existingIdx = -1;
  for (let i = 1; i < rows.length; i++) {
    if (rows[i][0] === weekStart) { existingIdx = i + 1; break; } // 1-based sheet row
  }

  if (existingIdx > 0) {
    await writeRow(token, TAB_PLANS, existingIdx, row);
    return `✓ Updated plan for week of ${weekStart} (${d.phase || 'unknown phase'})`;
  }
  await appendRows(token, TAB_PLANS, [row]);
  return `✓ Logged plan for week of ${weekStart} (${d.phase || 'unknown phase'})`;
}

async function cmdLogRecovery(jsonStr) {
  const d = parseJsonArg(jsonStr);
  const token = await getAccessToken();

  const date = d.date || todayStr();
  const row  = [
    date,
    d.recovery_pct    != null ? String(d.recovery_pct) : '',
    d.hrv             != null ? String(d.hrv) : '',
    d.rhr             != null ? String(d.rhr) : '',
    d.spo2            != null ? String(d.spo2) : '',
    d.strain          != null ? String(d.strain) : '',
    d.sleep_score     != null ? String(d.sleep_score) : '',
    d.sleep_duration  || '',
    d.note            || '',
  ];

  // Insert at top (row 2, after header) to keep newest-first order
  const meta  = await getSpreadsheetMeta(token);
  const sheet = (meta.sheets || []).find(s => s.properties.title === TAB_RECOVERY);
  if (!sheet) die('Recovery Trends tab not found. Run: sheets init');
  const wsId  = sheet.properties.sheetId;
  const batchUrl = `${SHEETS_API}/${sheetId()}:batchUpdate`;
  const batchRes = await httpRequest('POST', batchUrl, token, {
    requests: [{ insertDimension: {
      range: { sheetId: wsId, dimension: 'ROWS', startIndex: 1, endIndex: 2 },
      inheritFromBefore: false,
    }}],
  });
  if (batchRes.status !== 200) die(`Failed to insert row (HTTP ${batchRes.status}): ${JSON.stringify(batchRes.body)}`);
  await writeRow(token, TAB_RECOVERY, 2, row);
  return `✓ Logged recovery for ${date}: ${d.recovery_pct != null ? d.recovery_pct + '%' : ''} ${d.hrv ? 'HRV ' + d.hrv + 'ms' : ''}`.trim();
}

async function cmdGetPlan(weekStr) {
  const token  = await getAccessToken();
  const rows   = await readRows(token, TAB_PLANS);
  if (rows.length <= 1) return 'No plans logged yet.';

  const headers = rows[0];
  const target  = weekStr || currentMondayStr();

  // Find the row with matching week start, or the most recent one
  const dataRows = rows.slice(1);
  let match = dataRows.find(r => r[0] === target);
  if (!match) {
    // Return most recent
    match = dataRows[dataRows.length - 1];
  }

  if (!match) return 'No plan found.';

  const lines = [`── Weekly Plan: ${match[0] || 'unknown week'} ─────────────────────`];
  lines.push(`  Week #: ${match[1] || 'N/A'}  |  Phase: ${match[2] || 'N/A'}  |  Target volume: ${match[10] || 'N/A'} km`);
  lines.push('');
  const days = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];
  days.forEach((day, i) => {
    const session = match[3 + i] || 'rest';
    lines.push(`  ${day}: ${session}`);
  });
  if (match[11]) {
    lines.push('');
    lines.push(`  Coach notes: ${match[11]}`);
  }
  return lines.join('\n');
}

async function cmdGetWorkouts(days) {
  const token  = await getAccessToken();
  const rows   = await readRows(token, TAB_WORKOUTS);
  if (rows.length <= 1) return 'No workouts logged yet.';

  const cutoff  = daysAgo(days);
  const headers = rows[0];
  const data    = rows.slice(1).filter(r => r[0] && r[0] >= cutoff);

  if (!data.length) return `No workouts logged in the last ${days} days.`;

  // Cols: 0=Date 1=Day 2=Sport 3=Distance 4=Duration 5=HR 6=Pace/Power 7=Status 8=Notes 9=Coach Note
  const lines = [`── Workout Log: last ${days} days ─────────────────────`];
  for (const r of data) {
    lines.push('');
    const status = r[7] ? ` [${r[7]}]` : '';
    lines.push(`  [${r[0] || '?'}] ${r[1] || ''} — ${r[2] || 'activity'}${status}`);
    const detail = [r[3] ? r[3] + ' km' : '', r[4] || '', r[6] ? 'avg ' + r[6] : '', r[5] ? 'HR ' + r[5] : ''].filter(Boolean).join('  ·  ');
    if (detail) lines.push(`    ${detail}`);
    if (r[8]) lines.push(`    ${r[8]}`);
    if (r[9]) lines.push(`    Coach: ${r[9]}`);
  }
  lines.push('');
  lines.push(`  Total: ${data.length} workouts`);
  const totalKm = data.reduce((s, r) => s + (parseFloat(r[3]) || 0), 0);
  if (totalKm > 0) lines.push(`  Distance: ${totalKm.toFixed(1)} km`);
  return lines.join('\n');
}

async function cmdLogFitness(jsonStr) {
  const d     = parseJsonArg(jsonStr);
  const token = await getAccessToken();

  // Cols: 0=Date 1=VDOT 2=AE Index 3=7d HRV 4=28d Volume 5=7d Recovery %
  const date = d.date || todayStr();
