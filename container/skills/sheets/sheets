    date,
    d.vdot        != null ? +d.vdot        : '',
    d.ae_index    != null ? +d.ae_index    : '',
    d.hrv_7d      != null ? +d.hrv_7d      : '',
    d.volume_28d  != null ? +d.volume_28d  : '',
